    "version": "0.2.0",
    "configurations": [
        {
            "name": "(Windows) 启动",
            "type": "cppvsdbg",
            "request": "launch",
            "preLaunchTask": "Rust: cargo build - rust",
            "envFile": "${workspaceFolder}/.vscode/rust.env",
            "program": "${workspaceFolder}/rust/target/debug/leetcode-by-rust.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/rust",
            "environment": [],
            "externalConsole": false
        },
        {
            "name": "(Linux) Launch",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/rust/target/debug/leetcode-by-rust.exe",
            "args": [],
            "cwd": "${workspaceFolder}/rust"
        }
    ]
}
